# RATS Backend Configuration
# Copy this to .env and customize for your environment

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8888
RELOAD=false

# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEPALIVE=60
MQTT_QOS=1

# Topics
MQTT_DEVICE_DATA_TOPIC=device_data
MQTT_SERVER_INFO_TOPIC=server_info
MQTT_TEST_COMMAND_TOPIC=test_commands
MQTT_TEST_RESULT_TOPIC=test_results

# SSL/TLS
USE_SSL=false
CERT_FILE=ssl/cert.pem
KEY_FILE=ssl/key.pem
VERIFY_CERT=false

# Paths
CONFIG_DIR=./config
LOG_DIR=./logs
REPORT_DIR=./reports

# Timeouts (seconds)
DEVICE_TIMEOUT=30
TEST_TIMEOUT=300
SSH_TIMEOUT=30
CONNECTION_TIMEOUT=10

# Features
ENABLE_ASYNC=true
ASYNC_WORKERS=4
MAX_CONCURRENT_TESTS=5
